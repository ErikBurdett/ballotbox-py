DJANGO_DEBUG=1
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000

DATABASE_URL=postgis://avd:avd@db:5432/avd
REDIS_URL=redis://redis:6379/0

CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Democracy Works (DW) Elections API (v2)
# Keep your key out of git. Put it in `.env` only.
DEMOCRACY_WORKS_API_KEY=
# Sync scope (choose one approach)
DEMOCRACY_WORKS_STATE_CODE=TX
# Year-scoped state sync (recommended): defaults to current year if unset
DEMOCRACY_WORKS_ELECTION_YEAR=2026
# Optional date range for state sync (defaults to backfill since 2020 through ~3 years ahead)
# DEMOCRACY_WORKS_START_DATE=2020-01-01
# DEMOCRACY_WORKS_END_DATE=
# Or sync by address (recommended for local testing)
# DEMOCRACY_WORKS_ADDRESS_STREET=813 Howard Street
# DEMOCRACY_WORKS_ADDRESS_CITY=Oswego
# DEMOCRACY_WORKS_ADDRESS_STATE_CODE=NY
# DEMOCRACY_WORKS_ADDRESS_ZIP=13126
# DEMOCRACY_WORKS_ADDRESS_ZIP4=

# Optional: keep empty to disable Sentry
SENTRY_DSN=
