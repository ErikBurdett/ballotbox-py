DJANGO_DEBUG=1
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000

DATABASE_URL=postgis://avd:avd@db:5432/avd
REDIS_URL=redis://redis:6379/0

CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Democracy Works (DW) Elections API (v2)
# Keep your key out of git. Put it in `.env` only.
BALLOTPEDIA_API_KEY=
# BALLOTPEDIA_API4_BASE_URL=https://api4.ballotpedia.org/data
# Primary state for photo sync / UI defaults when DW state is unset (fallback TX)
# BALLOTPEDIA_SYNC_STATE_CODE=TX
# Daily Celery job: sync_ballotpedia_geographic_scheduled (quota-friendly defaults)
# BALLOTPEDIA_GEO_BEAT_ENABLED=true
# BALLOTPEDIA_GEO_MAX_REQUESTS=160
# BALLOTPEDIA_GEO_MAX_ELECTION_DATES=14
# BALLOTPEDIA_GEO_MAX_TX_CALENDAR_PAGES=10
# BALLOTPEDIA_GEO_TX_LOCAL_STATE_PAGES=1
# BALLOTPEDIA_GEO_SKIP_IF_FETCHED_DAYS=1
# BALLOTPEDIA_GEO_WITH_OFFICEHOLDERS=false

# Optional legacy — leave empty to skip; existing DW rows in DB are never deleted by the app
DEMOCRACY_WORKS_API_KEY=
# Sync scope (choose one approach)
DEMOCRACY_WORKS_STATE_CODE=TX
# Set true so Celery/ingestion uses Amarillo multi-ZIP ballots (Potter + Randall). CLI: sync_democracy_works --amarillo-metro
# DEMOCRACY_WORKS_AMARILLO_METRO=false
# Year-scoped state sync (recommended): defaults to current year if unset
DEMOCRACY_WORKS_ELECTION_YEAR=2026
# Optional date range for state sync (defaults to backfill since 2020 through ~3 years ahead)
# DEMOCRACY_WORKS_START_DATE=2020-01-01
# DEMOCRACY_WORKS_END_DATE=
# Or sync by address (recommended for local testing)
# DEMOCRACY_WORKS_ADDRESS_STREET=813 Howard Street
# DEMOCRACY_WORKS_ADDRESS_CITY=Oswego
# DEMOCRACY_WORKS_ADDRESS_STATE_CODE=NY
# DEMOCRACY_WORKS_ADDRESS_ZIP=13126
# DEMOCRACY_WORKS_ADDRESS_ZIP4=

# Optional: keep empty to disable Sentry
SENTRY_DSN=
